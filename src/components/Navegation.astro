            </a>
        </li>
        <li>
            <a href="#requisitos" class="group flex items-center justify-between w-full text-xs md:text-sm font-medium text-[#736063] hover:text-[#3d6966] transition-all duration-300">
                <span class="flex items-center gap-2">
                    <span class="text-xs text-[#4a7a77] transition-transform duration-300 group-hover:scale-110">🧸</span> Requisitos previos
                </span>
                <span class="flex-1 mx-2 border-b border-dotted border-[#cbdad8] group-hover:border-[#4a7a77] transition-colors"></span>
                <span class="font-serif text-[11px] bg-white/80 px-2 py-0.5 rounded-md border border-[#d2ebe9]">03</span>
            </a>
        </li>
        <li>
            <a href="#estructura" class="group flex items-center justify-between w-full text-xs md:text-sm font-medium text-[#736063] hover:text-[#3d6966] transition-all duration-300">
