---
import '../styles/global.css'
---
<nav class="w-full py-2">
    <ul class="space-y-3">
        <li>
            <a href="#astro" class="group flex items-center justify-between w-full text-xs md:text-sm font-medium text-[#736063] hover:text-[#a86b74] transition-all duration-300">
                <span class="flex items-center gap-2">
                    <span class="text-xs text-[#c4848e] transition-transform duration-300 group-hover:rotate-12">🌸</span> Astro
                </span>
                <span class="flex-1 mx-2 border-b border-dotted border-[#cbdad8] group-hover:border-[#c4848e] transition-colors"></span>
                <span class="font-serif text-[11px] bg-white/80 px-2 py-0.5 rounded-md border border-[#f5e1e2]">01</span>
            </a>
        </li>
        <li>
            <a href="#tailwind" class="group flex items-center justify-between w-full text-xs md:text-sm font-medium text-[#736063] hover:text-[#a86b74] transition-all duration-300">
                <span class="flex items-center gap-2">
                    <span class="text-xs text-[#c4848e] transition-transform duration-300 group-hover:rotate-12">🎀</span> Tailwind CSS
                </span>
                <span class="flex-1 mx-2 border-b border-dotted border-[#cbdad8] group-hover:border-[#c4848e] transition-colors"></span>
