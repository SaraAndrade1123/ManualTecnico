---
import '../styles/global.css';
const { pageTitle } = Astro.props;
---
<header id="inicio" class="text-center pt-20 pb-12 border-b border-[#fce4e6] mb-8 md:mb-12">
    <h1 class="text-3xl sm:text-4xl md:text-6xl font-serif font-black text-[#a86b74] tracking-wide mb-4 px-2 drop-shadow-xs">
        {pageTitle || "Manual de referencias Técnicas"} ᶻ 𝘇 𐰁
    </h1>
    <div class="inline-flex items-center justify-center gap-2 text-[#3d6966] bg-[#e6f4f3] border border-[#cbdad8] px-5 py-1.5 rounded-full text-xs font-bold tracking-widest uppercase shadow-2xs">
        <span>✦</span> Astro + Tailwind CSS <span>✦</span>
    </div>
</header>